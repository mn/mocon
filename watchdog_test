from watchdog.observers import Observer
from watchdog.events import FileSystemEventHandler
from reportlab.lib.pagesizes import letter
from reportlab.lib import colors
from reportlab.pdfgen import canvas
import os
import time

# Define the folder to monitor
WATCH_DIRECTORY = r"C:\Users\client27\Desktop\PRN_Files"  # Change this path accordingly

# PDF generation function
def create_pdf_from_prn(prn_file):
    # Set up the file path for the PDF
    pdf_file = prn_file.replace(".PRN", ".pdf")
    
    # Create a PDF canvas
    c = canvas.Canvas(pdf_file, pagesize=letter)
    
    # Set up margins
    left_margin = 72  # 1 inch from the left (72 points = 1 inch)
    right_margin = 72  # 1 inch from the right
    top_margin = 72  # 1 inch from the top
    bottom_margin = 72  # 1 inch from the bottom
    
    width, height = letter  # Get the width and height of the page
    
    # Read the content of the PRN file
    try:
        with open(prn_file, 'r') as file:
            prn_content = file.read()
    except Exception as e:
        print(f"Error reading {prn_file}: {e}")
        return
    
    # Split the content into lines
    lines = prn_content.splitlines()
    
    # Set the font and size for normal lines
    c.setFont("Helvetica", 10)
    
    # Calculate text width and position to center it
    text_width = width - left_margin - right_margin
    y_position = height - top_margin  # Start at the top of the page
    
    # First line: Bold and larger font
    first_line = lines[0].strip()
    if first_line:
        # Make the first line larger and bold
        c.setFont("Helvetica-Bold", 14)
        text_length = c.stringWidth(first_line, "Helvetica-Bold", 14)
        x_position = (width - text_length) / 2
        c.drawString(x_position, y_position, first_line)
        y_position -= 18  # Adjust space after the first line
        
        # Draw a line under the first line
        c.setStrokeColor(colors.black)  # Set color for the line (black)
        c.setLineWidth(1)  # Set the line width
        c.line(left_margin, y_position, width - right_margin, y_position)  # Draw a horizontal line
        
        # Add extra space below the line before the next data
        y_position -= 12

        c.setFont("Helvetica", 10)  # Reset to normal font for the rest of the lines
    
    # Loop through the remaining lines
    for line in lines[1:]:
        text = line.strip()
        
        # Skip empty lines
        if not text:
            continue
        
        # Calculate the text length
        text_length = c.stringWidth(text, "Helvetica", 10)
        
        # Center the text horizontally
        x_position = (width - text_length) / 2  # Center the text based on its width
        
        # Write the text to the PDF
        c.drawString(x_position, y_position, text)
        
        # Move to the next line
        y_position -= 12  # Adjust this value if you want more or less space between lines
        
        # Check if we need to create a new page
        if y_position < bottom_margin:
            c.showPage()  # Create a new page
            c.setFont("Helvetica", 10)
            y_position = height - top_margin  # Reset the y position for the new page
    
    # Add a custom gap before the custom field
    y_position -= 18  # Add extra space for the gap before custom field
    
    # Add the custom field (without bold)
    custom_text = "Reweigh of rejected cap:"
    c.setFont("Helvetica", 10)  # Regular font for the custom text
    text_length = c.stringWidth(custom_text, "Helvetica", 10)
    x_position = (width - text_length) / 2  # Center it horizontally
    c.drawString(x_position, y_position, custom_text)
    y_position -= 18  # Space after custom field
    
    # Optional: You can add more details here for the reweigh (e.g., a value or description)
    
    # Save the PDF
    c.save()
    print(f"PDF saved as {pdf_file}")

# Define the event handler for the directory
class PRNHandler(FileSystemEventHandler):
    def on_created(self, event):
        if event.is_directory:
            return
        if event.src_path.endswith(".PRN"):
            print(f"Event detected: created, Path: {event.src_path}")
            create_pdf_from_prn(event.src_path)

# Set up the observer to monitor the folder
observer = Observer()
handler = PRNHandler()
observer.schedule(handler, WATCH_DIRECTORY, recursive=False)

# Start monitoring
print(f"Watching directory: {WATCH_DIRECTORY}")
observer.start()

try:
    while True:
        time.sleep(1)
except KeyboardInterrupt:
    observer.stop()
observer.join()
